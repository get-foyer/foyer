# Agent Foyer — environment configuration
# Copy this file to .env and fill in values, OR run `npm run setup` which does it for you.

# Port the dashboard server listens on (default: 4317)
FOYER_PORT=4317

# LLM provider: "codex" | "claude-cli" | "anthropic-api"
# Set by `npm run setup`. codex and claude-cli use your existing subscription.
FOYER_PROVIDER=codex

# Only required if FOYER_PROVIDER=anthropic-api
# ANTHROPIC_API_KEY=sk-ant-...

# Only required if FOYER_PROVIDER=anthropic-api
# FOYER_ANTHROPIC_MODEL=claude-haiku-4-5
